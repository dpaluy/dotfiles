cdx() {
    case "$1" in
        help|-h|--help)
            cat <<'USAGE' >&2
Usage: cdx [codex args...]
Special: -r/--resume resumes the most recent session
         update -> npm install -g @openai/codex@latest
USAGE
            return 0 ;;
        update)
            npm install -g @openai/codex@latest
            return 0 ;;
    esac

    # Codex 0.144 moved resume from a global -r flag to a subcommand. Preserve
    # the established cdx shorthand while allowing an explicit session ID.
    case "${1:-}" in
        -r|--resume)
            shift
            if [[ $# -eq 0 ]]; then
                set -- resume --last
            else
                set -- resume "$@"
            fi
            ;;
    esac

    codex --dangerously-bypass-approvals-and-sandbox --search "$@"
}
