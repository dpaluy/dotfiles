# AI Tools Configuration
# Add machine-specific AI settings to ~/.local/dotfiles/ai.local

# ------------------------------------------------------------------------------
# AI Functions
# ------------------------------------------------------------------------------

[[ -f "$HOME/dotfiles/zsh/ai-tools/git" ]] && source "$HOME/dotfiles/zsh/ai-tools/git"
[[ -f "$HOME/dotfiles/zsh/ai-tools/codex" ]] && source "$HOME/dotfiles/zsh/ai-tools/codex"
[[ -f "$HOME/dotfiles/zsh/ai-tools/skills" ]] && source "$HOME/dotfiles/zsh/ai-tools/skills"

# ------------------------------------------------------------------------------
# Claude Code
# ------------------------------------------------------------------------------

alias cly="claude --dangerously-skip-permissions"
alias cly-team="CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1 claude --dangerously-skip-permissions"

# Enable background task execution
export ENABLE_BACKGROUND_TASKS=true

# Automatically run eligible tasks in background
export FORCE_AUTO_BACKGROUND_TASKS=true

# Keep bash commands in project directory
export CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR=true

export ENABLE_TOOL_SEARCH=true

export MAX_THINKING_TOKENS=31999
export TEAMMATE_TOOL_ENABLED=true

export DISABLE_TELEMETRY=1
export CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
