# Ghostty Configuration
# https://ghostty.org/docs/config
# Machine-specific settings (font, size, theme) go in ~/.local/dotfiles/ghostty.local

# ------------------------------------------------------------------------------
# Theme
# ------------------------------------------------------------------------------

# Omarchy theme integration (Linux) - only loads if file exists
config-file = ?"~/.config/omarchy/current/theme/ghostty.conf"

# Override with specific theme (uncomment to use)
# theme = "Catppuccin Mocha"

# ------------------------------------------------------------------------------
# Font (override in ~/.local/dotfiles/ghostty.local)
# ------------------------------------------------------------------------------

# Default font - override size in local config if needed
# font-family = "MartianMono Nerd Font"
font-family = "JetBrainsMono Nerd Font"
font-size = 12
font-thicken = true

# ------------------------------------------------------------------------------
# Window
# ------------------------------------------------------------------------------

background-blur-radius = 20
confirm-close-surface = false
unfocused-split-opacity = 0.5
window-save-state = always
window-padding-x = 12
window-padding-y = 12

# ------------------------------------------------------------------------------
# Quick Terminal (quake-style dropdown)
# ------------------------------------------------------------------------------

quick-terminal-position = top
quick-terminal-screen = mouse
quick-terminal-autohide = true
quick-terminal-animation-duration = 0.15

# ------------------------------------------------------------------------------
# Cursor
# ------------------------------------------------------------------------------

cursor-style = block
cursor-style-blink = false
adjust-cursor-thickness = 175%

# ------------------------------------------------------------------------------
# Mouse
# ------------------------------------------------------------------------------

mouse-hide-while-typing = true
mouse-scroll-multiplier = 1.0
copy-on-select = clipboard

# ------------------------------------------------------------------------------
# Security
# ------------------------------------------------------------------------------

clipboard-paste-protection = true

# ------------------------------------------------------------------------------
# Shell Integration
# ------------------------------------------------------------------------------

shell-integration = zsh
shell-integration-features = no-cursor,no-title,ssh-env

# Prevents ^[[?2026;2$y leak: xterm-ghostty terminfo advertises mode 2026, triggering a Starship/epoll race condition
term = xterm-256color

# Platform-specific keybindings and backend settings. install/symlinks.sh links
# the correct fragment to this path for the detected operating system.
config-file = ?"~/.config/ghostty/platform.conf"

# ------------------------------------------------------------------------------
# Local overrides (font, size, theme preferences)
# ------------------------------------------------------------------------------

config-file = ?"~/.local/dotfiles/ghostty.local"
