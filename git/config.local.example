# ~/.config/git/config example
# This file is local to each machine and includes the shared dotfiles config

[include]
    path = ~/dotfiles/git/config

[user]
    name = Your Name
    email = your.email@example.com
    # signingkey = YOUR_GPG_KEY_ID

# Uncomment to enable GPG signing
# [commit]
#     gpgsign = true

# [gpg]
#     program = gpg

# Work-specific settings (example)
# [includeIf "gitdir:~/work/"]
#     path = ~/.config/git/work.config
