{
  "description": "Portable lifecycle hooks managed by the dotfiles repository.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env python3 \"$HOME/.codex/hooks/block-destructive-commands.py\"",
            "timeout": 5,
            "statusMessage": "Checking for destructive commands"
          }
        ]
      }
    ]
  }
}
